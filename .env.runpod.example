# =========================================================
# RunPod deployment env template.
# Copy to .env on the pod, then `docker compose up -d --build`.
# =========================================================

# --- Persistent data (RunPod network volume mounted at /workspace) ---
DATA_DIR=/workspace
CHROMA_PATH=/workspace/chroma_db
CACHE_FILE=/workspace/cache.json
CHECKPOINT_FILE=/workspace/sync_checkpoint.json
CLOUD_LINKS_FILE=/workspace/cloud_links.json
OLLAMA_MODELS=/workspace/ollama_models
HF_HOME=/workspace/hf_cache
SENTENCE_TRANSFORMERS_HOME=/workspace/hf_cache

# --- Ollama (runs inside the same container) ---
OLLAMA_URL=http://127.0.0.1:11434/api/generate
MODEL_NAME=qwen2.5:14b
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_STREAM_TIMEOUT_SECONDS=300

# --- MySQL (docker-compose service named `mysql`) ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=rag
MYSQL_USER=rag
MYSQL_PASSWORD=change-me
DATABASE_URL=mysql://rag:change-me@mysql:3306/rag

# --- Optional ---
REDIS_URL=
CACHE_TTL_SECONDS=86400
CLOUD_IMPORT_TIMEOUT_SECONDS=120
BACKGROUND_SYNC_INTERVAL_SECONDS=30
