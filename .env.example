# Optional: path to JSON/YAML config file
APP_CONFIG_FILE=config.json

# Optional: direct overrides (highest priority)
OLLAMA_URL=http://localhost:11434/api/generate
MODEL_NAME=phi3:mini
OLLAMA_TIMEOUT_SECONDS=180
OLLAMA_STREAM_TIMEOUT_SECONDS=300
CLOUD_IMPORT_TIMEOUT_SECONDS=120
BACKGROUND_SYNC_INTERVAL_SECONDS=30
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400
